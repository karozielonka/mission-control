# Server
PORT=4000

# Path to your local platform repo (used as working directory for Claude agents)
PLATFORM_DIR=

# GitHub
# Personal access token: https://github.com/settings/tokens
# Required scopes: repo, read:user
GITHUB_PERSONAL_ACCESS_TOKEN=

# Linear
# Personal API key from https://linear.app/settings/api
LINEAR_API_KEY=

# Sentry
# Auth token from https://sentry.io/settings/account/api/auth-tokens/
SENTRY_URL=https://sentry.io
SENTRY_ACCESS_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
